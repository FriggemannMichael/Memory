{
  "name": "memory",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:memory": "ng build --base-href /memory/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.0.0",
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/router": "^21.2.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.2",
    "@angular-devkit/schematics": "^21.2.2",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@eslint/js": "^10.0.1",
    "@nx/angular": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@schematics/angular": "^21.2.2",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "nx": "22.5.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  }
}
